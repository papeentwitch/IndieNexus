generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Game {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  description     String
  genre           String
  platforms       String
  releaseDate     DateTime
  status          String
  image           String
  developer       String
  publisher       String
  country         String
  multiplayer     Boolean
  coop            Boolean
  controller      Boolean
  steamUrl        String?
  officialWebsite String?
  trailerUrl      String?
  createdAt       DateTime @default(now())
}