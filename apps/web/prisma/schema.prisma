generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Game {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  description     String
  genre           String
  platforms       String
  releaseDate     DateTime
  status          String
  image           String
  developer       String
  publisher       String
  country         String
  multiplayer     Boolean
  coop            Boolean
  controller      Boolean
  steamUrl        String?
  officialWebsite String?
  trailerUrl      String?
  rating          Float?
  metacritic      Int?
  playtime        Int?
  steamAppId       Int?
  releaseDateText  String?
  hasDemo          Boolean @default(false)
  hasPlaytest      Boolean @default(false)
  isAvailableSteam Boolean @default(true)
  isFree            Boolean @default(false)
  price             String?
  discount          Int?
  vrOnly            Boolean @default(false)

  screenshots     String?
  stores          String?
  tags            String?
  translations GameTranslation[]

  rawgId          Int?
  updatedAt       DateTime @default(now()) @updatedAt
  createdAt       DateTime @default(now())
}
model GameTranslation {
  id          Int    @id @default(autoincrement())

  gameId      Int
  locale      String

  title       String
  description String

  game        Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, locale])
}